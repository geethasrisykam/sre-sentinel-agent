{
  "name": "@sre-sentinel/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify backend that receives Dynatrace alerts, runs the Gemini agent loop, gates remediation behind human approval, and persists every step to SQLite.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "start": "node --env-file=../../.env.local dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/sensible": "^5.6.0",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@sre-sentinel/shared": "*",
    "better-sqlite3": "^11.5.0",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
