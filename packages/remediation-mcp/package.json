{
  "name": "@sre-sentinel/remediation-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Custom MCP server exposing remediation actions to the SRE Sentinel agent (restartPod, rollbackDeployment, scaleService).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sre-sentinel-remediation-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@sre-sentinel/shared": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
