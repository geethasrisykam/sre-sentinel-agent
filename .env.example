# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Google Gemini (development via AI Studio, no billing required) ---
# Get a free key at https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=

# --- Google Cloud (production deploy, fill in when billing is active) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
VERTEX_AI_LOCATION=us-central1

# --- Dynatrace (activate trial ~Day 12, see project memory) ---
# Trial signup: https://www.dynatrace.com/trial/
DYNATRACE_ENVIRONMENT_URL=
DYNATRACE_API_TOKEN=

# --- Orchestrator service ---
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_LOG_LEVEL=info

# --- Remediation MCP server ---
REMEDIATION_MCP_PORT=8081
# REAL or MOCK per tool (production demo flips restartPod to REAL)
REMEDIATION_RESTART_POD_MODE=MOCK
REMEDIATION_ROLLBACK_MODE=MOCK
REMEDIATION_SCALE_MODE=MOCK
# Cloud Run dummy service used as the real restart target (filled after deploy)
VICTIM_APP_SERVICE_NAME=
VICTIM_APP_REGION=us-central1

# --- Dashboard auth (single shared password for hackathon demo) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=
DASHBOARD_DEMO_PASSWORD=changeme-pick-something-strong
# Optional: force the session cookie secure flag on/off. Defaults to
# NODE_ENV === "production" (i.e. true on Cloud Run, false locally).
# COOKIE_SECURE=true

# --- Frontend (Vite reads VITE_-prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8080
